---
const { t } = Astro.props;
---

<section id="sobre-mi" class="section-title">
    <h2 class="h4">
        <i class="bi bi-person-circle me-2 text-primary"></i>
        {t.about.title}
    </h2>

    <div class="card shadow-sm">
        <div class="card-body">
            <p class="mb-3">
                {t.about.paragraph}
            </p>

            <ul class="mb-0">
                {t.about.points.map((point) => (
                    <li>{point}</li>
                ))}
            </ul>
        </div>
    </div>
</section>
