---
const { t } = Astro.props;
---

<section id="sobre-mi" class="section-title">
    <h2 class="h4">
        <i class="bi bi-person-circle me-2 text-primary"></i>
        {t.about.title}
    </h2>

    <div class="card shadow-sm">
        <div class="card-body">
            <p>
                {t.about.intro.beforeBackend}
                <span class="text-highlight-about">{t.about.intro.backend}</span>{t.about.intro.beforeFrontend}
                <span class="text-highlight-about">{t.about.intro.frontend}</span>{t.about.intro.beforeDatabases}
                <span class="text-highlight-about">{t.about.intro.databases}</span>{t.about.intro.beforeDocumentation}
                <span class="text-highlight-about">{t.about.intro.documentation}</span>{t.about.intro.beforeDeployment}
                <span class="text-highlight-about">{t.about.intro.deployment}</span>{t.about.intro.end}
            </p>

            <ul class="mb-0">
                {t.about.points.map((point) => (
                    <li>{point}</li>
                ))}
            </ul>
        </div>
    </div>
</section>
