---
const { t } = Astro.props;
---

<section id="experiencia" class="section-title experience-section">
    <h2 class="h4">
        <i class="bi bi-briefcase me-2 text-primary" aria-hidden="true"></i>
        {t.experience.title}
    </h2>

    <div class="experience-timeline">
        {t.experience.items.map((item) => (
            <article class="experience-timeline__item">
                <div class="experience-timeline__marker">
                    <i class={item.icon} aria-hidden="true"></i>
                </div>

                <div class="experience-card">
                    <h3 class="experience-card__role">
                        {item.role}
                    </h3>

                    <p class="experience-card__company">
                        {item.company}
                    </p>
                    
                    <p class="experience-card__date">
                        {item.date}
                    </p>

                    <p class="experience-card__description">
                        {item.description}
                    </p>

                    <ul class="experience-card__tasks">
                        {item.tasks.map((task) => (
                            <li>{task}</li>
                        ))}
                    </ul>
                </div>
            </article>
        ))}
    </div>
</section>
