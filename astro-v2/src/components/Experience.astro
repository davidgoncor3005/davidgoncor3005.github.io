---
const { t } = Astro.props;
---

<section id="experiencia" class="section-title">
    <h2 class="h4">
        <i class="bi bi-briefcase me-2 text-primary"></i>
        {t.experience.title}
    </h2>

    <div class="row g-3">
        <div class="col-md-6">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h3 class="h6 mb-1">
                        <i class="bi bi-code-square me-1 text-primary"></i>
                        {t.experience.ntt.role}
                    </h3>

                    <p class="mb-1 fw-semibold">{t.experience.ntt.company}</p>

                    <p class="mb-2 small text-secondary">
                        {t.experience.ntt.date}
                    </p>

                    <p class="mb-3">
                        {t.experience.ntt.description}
                    </p>

                    <ul class="mb-0 small">
                        {t.experience.ntt.tasks.map((task) => (
                            <li>{task}</li>
                        ))}
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h3 class="h6 mb-1">
                        <i class="bi bi-pc-display-horizontal me-1 text-secondary"></i>
                        {t.experience.gines.role}
                    </h3>

                    <p class="mb-1 fw-semibold">{t.experience.gines.company}</p>

                    <p class="mb-2 small text-secondary">
                        {t.experience.gines.date}
                    </p>

                    <p class="mb-3">
                        {t.experience.gines.description}
                    </p>

                    <ul class="mb-0 small">
                        {t.experience.gines.tasks.map((task) => (
                            <li>{task}</li>
                        ))}
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>
