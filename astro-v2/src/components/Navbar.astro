---
const { t, lang } = Astro.props;

const isSpanish = lang === "es";
const isEnglish = lang === "en";
---

<nav
    class="portfolio-navbar"
    aria-label={lang === "en" ? "Main navigation" : "Navegación principal"}
>
    <div class="portfolio-navbar__inner">
        <ul class="portfolio-navbar__links">
            <li>
                <a class="portfolio-navbar__link" href="#sobre-mi">
                    {t.nav.about}
                </a>
            </li>

            <li>
                <a class="portfolio-navbar__link" href="#experiencia">
                    {t.nav.experience}
                </a>
            </li>

            <li>
                <a class="portfolio-navbar__link" href="#tecnologias">
                    {t.nav.technologies}
                </a>
            </li>

            <li>
                <a class="portfolio-navbar__link" href="#proyectos">
                    {t.nav.projects}
                </a>
            </li>

            <li>
                <a class="portfolio-navbar__link" href="#contacto">
                    {t.nav.contact}
                </a>
            </li>
        </ul>

        <span class="portfolio-navbar__divider" aria-hidden="true">|</span>

        <div class="portfolio-navbar__controls">
            <div
                class="lang-group"
                role="group"
                aria-label={lang === "en" ? "Language selector" : "Selector de idioma"}
            >
                <a
                    href="/"
                    class={isSpanish ? "lang-link is-active" : "lang-link"}
                    aria-current={isSpanish ? "page" : undefined}
                    aria-label="Ver portfolio en español"
                >
                    ES
                </a>

                <a
                    href="/en/"
                    class={isEnglish ? "lang-link is-active" : "lang-link"}
                    aria-current={isEnglish ? "page" : undefined}
                    aria-label="View portfolio in English"
                >
                    EN
                </a>
            </div>

            <button
                id="themeToggle"
                class="theme-toggle"
                type="button"
                aria-label={lang === "en" ? "Switch color theme" : "Cambiar tema de color"}
            >
                <i id="themeIcon" class="bi bi-moon" aria-hidden="true"></i>
            </button>
        </div>
    </div>
</nav>
