---
const { t } = Astro.props;
---

<header class="hero-section border-bottom">
    <div class="container">
        <div class="hero-content">
            <div class="hero-avatar-wrapper">
                <img
                    src="/images/david.webp"
                    alt={t.hero.avatarAlt}
                    class="avatar"
                />
            </div>

            <div class="hero-copy">
                <a
                    href="https://www.linkedin.com/in/david-gonz%C3%A1lez-c%C3%B3rdoba/"
                    class="hero-status text-decoration-none"
                    target="_blank"
                    rel="noopener"
                >
                    <i class="bi bi-briefcase me-1" aria-hidden="true"></i>
                    <span>{t.hero.badge}</span>
                </a>

                <h1 class="display-6 fw-bold mb-3">
                    {t.hero.titlePrefix}
                    <span class="hero-title-name">
                        {t.hero.name}
                    </span>
                </h1>

                <p class="hero-subtitle">
                    {t.hero.subtitle}
                </p>

                <p class="hero-description">
                    {t.hero.description}
                </p>

                <div class="hero-actions">
                    <a href="#proyectos" class="btn btn-primary">
                        <i class="bi bi-folder2-open me-1" aria-hidden="true"></i>
                        {t.hero.projectsButton}
                    </a>

                    <a
                        href="/docs/Curriculum_David_Gonzalez_Cordoba.pdf"
                        class="btn btn-outline-primary"
                        target="_blank"
                        rel="noopener"
                    >
                        <i class="bi bi-file-earmark-person me-1" aria-hidden="true"></i>
                        {t.hero.cvButton}
                    </a>

                    <a
                        href="https://github.com/davidgoncor3005"
                        class="btn btn-outline-dark"
                        target="_blank"
                        rel="noopener"
                    >
                        <i class="bi bi-github me-1" aria-hidden="true"></i>
                        {t.hero.githubButton}
                    </a>

                    <a
                        href="https://www.linkedin.com/in/david-gonz%C3%A1lez-c%C3%B3rdoba/"
                        class="btn btn-outline-info"
                        target="_blank"
                        rel="noopener"
                    >
                        <i class="bi bi-linkedin me-1" aria-hidden="true"></i>
                        {t.hero.linkedinButton}
                    </a>

                    <a href="mailto:dgoncor3005@gmail.com" class="btn btn-outline-secondary">
                        <i class="bi bi-envelope me-1" aria-hidden="true"></i>
                        {t.hero.contactButton}
                    </a>
                </div>
            </div>
        </div>
    </div>
</header>
