---
import projects from "../data/projects.json";
import technologies from "../data/technologies.json";
import "../styles/global.css";

const currentYear = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Portfolio de David González Córdoba</title>

    <meta
        name="description"
        content="Portfolio profesional de David González Córdoba, desarrollador web junior titulado en Desarrollo de Aplicaciones Web."
    />

    <link rel="icon" href="/images/favicon/favicon.svg" type="image/svg+xml" />

    <!-- Bootstrap 5 -->
    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
    />

    <!-- Bootstrap Icons -->
    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
        rel="stylesheet"
    />

    <!-- Bootstrap JS -->
    <script
        src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        defer
    ></script>
</head>

<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg bg-body-tertiary border-bottom">
        <div class="container">
            <a class="navbar-brand fw-semibold" href="#">David González Córdoba</a>

            <button
                class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#nav"
                aria-controls="nav"
                aria-expanded="false"
                aria-label="Abrir menú"
            >
                <span class="navbar-toggler-icon"></span>
            </button>

            <div id="nav" class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="#sobre-mi">Sobre mí</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#experiencia">Experiencia</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#tecnologias">Tecnologías</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#proyectos">Proyectos</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="mailto:dgoncor3005@gmail.com">Contacto</a>
                    </li>

                    <li class="nav-item ms-lg-2 my-lg-1">
                        <button
                            id="themeToggle"
                            class="btn btn-sm btn-outline-secondary"
                            type="button"
                            aria-label="Cambiar tema"
                        >
                            <i id="themeIcon" class="bi bi-moon"></i>
                        </button>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Hero -->
    <header class="py-5 bg-light border-bottom">
        <div class="container d-flex flex-column flex-sm-row align-items-center gap-4 text-center text-sm-start">
            <img
                src="/images/david.webp"
                alt="Avatar de David González Córdoba"
                class="avatar"
            />

            <div>
                <a
                    href="https://www.linkedin.com/in/david-gonz%C3%A1lez-c%C3%B3rdoba/"
                    class="badge text-bg-success mb-3 text-decoration-none"
                    target="_blank"
                    rel="noopener"
                >
                    <i class="bi bi-briefcase me-1"></i>
                    Disponible para trabajo
                </a>

                <h1 class="h2 mb-2">¡Hola! Soy David González Córdoba</h1>

                <p class="mb-3 text-secondary">
                    <strong>Desarrollador Web Junior | Titulado en Desarrollo de Aplicaciones Web.</strong><br />
                    Me gusta construir aplicaciones web útiles, bien estructuradas y fáciles de mantener.
                    Estoy centrado en seguir creciendo como desarrollador y aplicar buenas prácticas reales de desarrollo,
                    documentación y despliegue.
                </p>

                <div class="d-flex flex-wrap gap-2 justify-content-center justify-content-sm-start">
                    <a href="#proyectos" class="btn btn-primary">
                        <i class="bi bi-folder2-open me-1"></i>
                        Ver proyectos
                    </a>

                    <a
                        href="/docs/Curriculum_David_Gonzalez_Cordoba_Definitivo.pdf"
                        class="btn btn-outline-primary"
                        target="_blank"
                        rel="noopener"
                    >
                        <i class="bi bi-file-earmark-person me-1"></i>
                        Descargar CV
                    </a>

                    <a
                        href="https://github.com/davidgoncor3005"
                        class="btn btn-outline-dark"
                        target="_blank"
                        rel="noopener"
                    >
                        <i class="bi bi-github me-1"></i>
                        GitHub
                    </a>

                    <a
                        href="https://www.linkedin.com/in/david-gonz%C3%A1lez-c%C3%B3rdoba/"
                        class="btn btn-outline-info"
                        target="_blank"
                        rel="noopener"
                    >
                        <i class="bi bi-linkedin me-1"></i>
                        LinkedIn
                    </a>

                    <a href="mailto:dgoncor3005@gmail.com" class="btn btn-outline-secondary">
                        <i class="bi bi-envelope me-1"></i>
                        Contáctame
                    </a>
                </div>
            </div>
        </div>
    </header>

    <main class="container">
        <!-- Sobre mí -->
        <section id="sobre-mi" class="section-title">
            <h2 class="h4">
                <i class="bi bi-person-circle me-2 text-primary"></i>
                Sobre mí
            </h2>

            <div class="card shadow-sm">
                <div class="card-body">
                    <p class="mb-3">
                        Soy <strong>desarrollador web junior</strong> interesado especialmente en el desarrollo backend con
                        <strong>Java, Spring Boot y APIs REST</strong>, sin dejar de lado el frontend, las bases de datos,
                        la documentación y el despliegue.
                    </p>

                    <ul class="mb-0">
                        <li>
                            Destaco por mi actitud positiva, capacidad de adaptación y ganas de seguir aprendiendo.
                        </li>
                        <li>
                            Mi objetivo es integrarme en un equipo de desarrollo, aportar en proyectos reales y seguir creciendo profesionalmente.
                        </li>
                    </ul>
                </div>
            </div>
        </section>

        <!-- Experiencia laboral -->
        <section id="experiencia" class="section-title">
            <h2 class="h4">
                <i class="bi bi-briefcase me-2 text-primary"></i>
                Experiencia laboral
            </h2>

            <div class="row g-3">
                <div class="col-md-6">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h3 class="h6 mb-1">
                                <i class="bi bi-code-square me-1 text-primary"></i>
                                Desarrollador Web Junior
                            </h3>

                            <p class="mb-1 fw-semibold">NTT DATA Américo Vespucio · Contrato de prácticas</p>

                            <p class="mb-2 small text-secondary">
                                2025 - 2026 · Sevilla, Andalucía, España
                            </p>

                            <p class="mb-3">
                                Prácticas formativas en desarrollo de aplicaciones web, participando en tareas relacionadas
                                con backend, APIs REST y resolución de incidencias técnicas.
                            </p>

                            <ul class="mb-0 small">
                                <li>Desarrollo y mantenimiento de APIs REST con Spring Boot.</li>
                                <li>Documentación y pruebas de endpoints con OpenAPI/Swagger y Postman.</li>
                                <li>Uso de Git/GitHub, bases de datos y operaciones CRUD en entornos de desarrollo.</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h3 class="h6 mb-1">
                                <i class="bi bi-pc-display-horizontal me-1 text-secondary"></i>
                                Técnico de sistemas informáticos
                            </h3>

                            <p class="mb-1 fw-semibold">Departamento Informática Ayuntamiento de Gines · Contrato de prácticas</p>

                            <p class="mb-2 small text-secondary">
                                2024 · Gines, Andalucía, España
                            </p>

                            <p class="mb-3">
                                Prácticas formativas en el área de sistemas informáticos y soporte técnico.
                            </p>

                            <ul class="mb-0 small">
                                <li>Resolución de incidencias hardware y software en remoto y presencial.</li>
                                <li>Instalación, actualización y mantenimiento de equipos.</li>
                                <li>Atención a usuarios y apoyo en tareas del entorno técnico.</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Tecnologías -->
        <section id="tecnologias" class="section-title">
            <h2 class="h4">
                <i class="bi bi-tools me-2 text-primary"></i>
                Tecnologías y herramientas
            </h2>

            <div class="row g-3">
                {technologies.map((category) => (
                    <div class={category.category === "Despliegue" ? "col-lg-12" : "col-lg-6"}>
                        <div class="card h-100 shadow-sm tech-card">
                            <div class="card-body">
                                <h3 class="h6 text-uppercase text-muted mb-3">
                                    {category.category}
                                </h3>

                                <div class="tech-list">
                                    {category.items.map((technology) => (
                                        <span class="tech-item">
                                            <img src={`/${technology.icon}`} alt={technology.name} />
                                            {technology.name}
                                        </span>
                                    ))}
                                </div>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <!-- Proyectos -->
        <section id="proyectos" class="section-title">
            <h2 class="h4">
                <i class="bi bi-folder2-open me-2 text-primary"></i>
                Proyectos
            </h2>

            <div class="row g-4">
                {projects.map((project) => (
                    <div class="col-lg-4 col-md-6">
                        <article class="card h-100 shadow-sm project-card">
                            <div class="project-img-wrapper">
                                {project.image ? (
                                    <img
                                        src={`/${project.image}`}
                                        class="card-img-top project-img"
                                        alt={project.imageAlt}
                                    />
                                ) : (
                                    <div class="project-img-wrapper">
                                        <span></span>
                                    </div>
                                )}
                            </div>

                            <div class="card-body d-flex flex-column">
                                <h3 class="h5">{project.name}</h3>

                                <p class="text-secondary">
                                    {project.description}
                                </p>

                                <div class="project-stack mb-3">
                                    {project.stack.map((technology) => (
                                        <span>
                                            <img src={`/${technology.icon}`} alt="" />
                                            {technology.name}
                                        </span>
                                    ))}
                                </div>

                                <div class="mt-auto d-flex flex-wrap gap-2">
                                    <a
                                        href={project.repository}
                                        class="btn btn-outline-primary btn-sm"
                                        target="_blank"
                                        rel="noopener"
                                    >
                                        <i class="bi bi-github me-1"></i>
                                        Code
                                    </a>

                                    {project.preview && (
                                        <a
                                            href={project.preview}
                                            class="btn btn-primary btn-sm"
                                            target="_blank"
                                            rel="noopener"
                                        >
                                            <i class="bi bi-box-arrow-up-right me-1"></i>
                                            Preview
                                        </a>
                                    )}
                                </div>
                            </div>
                        </article>
                    </div>
                ))}
            </div>
        </section>

        <!-- Hablemos -->
        <section class="section-title">
            <h2 class="h4">
                <i class="bi bi-chat-dots me-2 text-primary"></i>
                Hablemos
            </h2>

            <div class="col-lg-12">
                <form action="https://formspree.io/f/mpqezryz" method="POST">
                    <div class="my-4">
                        <input
                            type="text"
                            class="form-control"
                            id="name"
                            name="name"
                            placeholder="Tu nombre"
                            aria-label="Tu nombre"
                            required
                        />
                    </div>

                    <div class="mb-4">
                        <input
                            type="email"
                            class="form-control"
                            id="email"
                            name="email"
                            placeholder="tuemail@ejemplo.com"
                            aria-label="tuemail@ejemplo.com"
                            required
                        />
                    </div>

                    <div class="mb-4">
                        <textarea
                            class="form-control"
                            id="message"
                            name="message"
                            rows="5"
                            placeholder="Escribe tu mensaje..."
                            aria-label="Escribe tu mensaje..."
                            required
                        ></textarea>
                    </div>

                    <button type="submit" class="col-lg-12 btn btn-primary">
                        Enviar Mensaje
                    </button>
                </form>
            </div>
        </section>
    </main>

    <footer class="border-top">
        <div class="container">
            <p class="mb-0 small">
                © <span id="y">{currentYear}</span>
                David González Córdoba. Todos los derechos reservados.
            </p>
        </div>
    </footer>

    <script is:inline>
        const themeToggle = document.getElementById('themeToggle');
        const themeIcon = document.getElementById('themeIcon');

        const savedTheme = localStorage.getItem('theme') || 'light';

        document.documentElement.setAttribute('data-theme', savedTheme);
        updateThemeIcon(savedTheme);

        themeToggle.addEventListener('click', () => {
            const currentTheme = document.documentElement.getAttribute('data-theme');
            const newTheme = currentTheme === 'dark' ? 'light' : 'dark';

            document.documentElement.setAttribute('data-theme', newTheme);
            localStorage.setItem('theme', newTheme);
            updateThemeIcon(newTheme);
        });

        function updateThemeIcon(theme) {
            if (theme === 'dark') {
                themeIcon.className = 'bi bi-moon';
            } else {
                themeIcon.className = 'bi bi-sun';
            }
        }
    </script>
</body>
</html>
